rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // スポット写真: spot_photos/{userId}/{filename}
    // 読み取り：認証済みユーザー全員（公開制御は Firestore の spots ルールで担保）
    // 書き込み：自分のフォルダのみ、画像ファイル限定、10MB 上限
    match /spot_photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.size < 10 * 1024 * 1024;
    }

    // アバター画像: avatars/{userId}/{filename}
    // 読み取り：認証済みユーザー全員
    // 書き込み：自分のフォルダのみ、画像ファイル限定、5MB 上限
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.size < 5 * 1024 * 1024;
    }
  }
}
